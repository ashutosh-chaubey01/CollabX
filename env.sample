## Example MongoDB Atlas connection (replace placeholders, do NOT commit real credentials)
# Use the full connection string provided by Atlas. Example format:
# mongodb+srv://<username>:<password>@cluster0.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/CollabX
## IMPORTANT: If your password contains special characters (for example: @, :, /, #, ?)
## you MUST URL-encode them in the connection string. For example `@` -> `%40`.
## Example with an '@' in the password: user:myP%40ssword@cluster0.mongodb.net
MONGODB_DB=CollabX
JWT_SECRET=change-this-secret-to-a-long-random-string
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=helloCollabX@gmail.com
AUTH_COOKIE_NAME=CollabX_token

